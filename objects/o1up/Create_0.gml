item_setup()

	name="1-UP"
	PickupSound=-1

itemeffect=function()
{

	
if itemto=1 with oPlayer if playerNO=1 lifescore_check(1,playerlNO,PlayerScore,1,1)	
if itemto=2 with oPlayer if playerNO=2 lifescore_check(1,playerlNO,PlayerScore,1,1)		
if itemto=3 with oPlayer if playerNO=3 lifescore_check(1,playerlNO,PlayerScore,1,1)		
if itemto=4 with oPlayer if playerNO=4 lifescore_check(1,playerlNO,PlayerScore,1,1)	
		
	
	}