with oFlashFX if name="BAD2a" or name="BAD2b" or name="BAD2c"
{hspeed=0
if name="BAD2a" sprite_index=spr_burglar_stand
if name="BAD2b" sprite_index=spr_burglarB_stand

}
with bad6 {hspeed=-2 sprite_index=spr_burglar_move}
with bad5 {hspeed=-2 sprite_index=spr_burglarB_move}
with bad8 {hspeed=-2 sprite_index=spr_burglar_move}


with diva1 {sprite_index=spr_viva_point image_index=2}
with diva2 {sprite_index=spr_hina_point image_index=2}
with diva3 {sprite_index=spr_bahati_point image_index=2}
with diva4 {sprite_index=spr_sofia_point image_index=2}


