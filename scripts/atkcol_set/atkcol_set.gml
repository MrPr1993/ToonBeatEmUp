/// @description atkcol_set(x,y,z,xScale,yScale,height)
/// @param x
/// @param y
/// @param z
/// @param xScale
/// @param yScale
/// @param height
function atkcol_set(argument0, argument1, argument2, argument3, argument4, argument5) {

	atkAddX=argument0
	atkAddY=argument1
	atkAddZ=argument2
	selfatk.image_xscale=argument3*image_xscale
	selfatk.image_yscale=argument4
	selfatk.height=argument5



}
