function animeditorpalette_check() {
	if spritePal=0 my_pal_sprite=spr_enemypal
	if spritePal=1 my_pal_sprite=spr_robotpal
	if spritePal=2 my_pal_sprite=spr_sneakpal
	if spritePal=3 my_pal_sprite=spr_weaponpal
	if spritePal=4 my_pal_sprite=spr_barrelpal
	if spritePal=4 my_pal_sprite=spr_playerpal



}


