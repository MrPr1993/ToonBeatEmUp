function animeditorpalette_check() {
	if spritePal=0 my_pal_sprite=spr_enemypal
	if spritePal=1 my_pal_sprite=spr_robotpal
	if spritePal=2 my_pal_sprite=spr_sneakpal
	if spritePal=3 my_pal_sprite=spr_weaponpal
	if spritePal=4 my_pal_sprite=spr_barrelpal
	if spritePal=5 my_pal_sprite=spr_playerpal
	if spritePal=5 my_pal_sprite=spr_ninjapal
	if spritePal=5 my_pal_sprite=spr_mummypal
	if spritePal=5 my_pal_sprite=spr_lobsterpal
	if spritePal=5 my_pal_sprite=spr_zombiepal
	if spritePal=5 my_pal_sprite=spr_plantpal
	if spritePal=5 my_pal_sprite=spr_boxerpal



}


