function hiscore_save(){


	
ini_open("GAMEDATA/hiscore.ini");
ini_write_real("HIGHSCORE1", "SCORE", global.HiScore1)
ini_write_string("HIGHSCORE1", "NAME", global.HiScoreName1)
ini_write_real("HIGHSCORE1", "FACE", global.HiScoreFace1)
ini_write_real("HIGHSCORE1", "STAGE", global.HiScoreStage1)
var hiscorepals=sprite_get_name(global.HiScorePalS1);
ini_write_string("HIGHSCORE1", "PALS", hiscorepals)
ini_write_real("HIGHSCORE1", "PAL", global.HiScorePal1)
ini_write_real("HIGHSCORE1", "DIF", global.HiScoreDif1)

