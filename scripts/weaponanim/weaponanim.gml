/// @description  @description weaponanim(weaponspr,weaponIndex,x,y,weaponangle,weaponcolor)
/// @param weaponspr
/// @param weaponIndex
/// @param x
/// @param y
/// @param weaponangle
/// @param weaponcolor
/// @param fname
function weaponanim(argument0, argument1, argument2, argument3, argument4, argument5) {



	weaponspr=argument0
	weaponIndex=argument1
	weaponX=argument2
	weaponY=argument3
	weaponangle=argument4
	weaponcolor=argument5



}

///This will be used if the enemy uses double weapons
function weaponanim_2(argument0, argument1, argument2, argument3, argument4, argument5) {



	weaponspr2=argument0
	weaponIndex2=argument1
	weaponX2=argument2
	weaponY2=argument3
	weaponangle2=argument4
	weaponcolor2=argument5



}
